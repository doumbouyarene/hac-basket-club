{
  "compilerOptions": {
    "types": ["vite/client"],
    /* Base */
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Qualité */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Alias requis par shadcn */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Silence le warning TS futur */
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}